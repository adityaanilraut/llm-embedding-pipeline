# --- paths ---
RAG_DATA_DIR=./data
RAG_INDEX_DIR=./indices
RAG_STATE_DB=./data/state.db

# --- embedding ---
RAG_EMBED_MODEL=BAAI/bge-small-en-v1.5
RAG_EMBED_DIM=384
RAG_EMBED_BATCH_SIZE=64

# --- chunking ---
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# --- ray ---
RAG_RAY_NUM_WORKERS=2

# --- faiss ---
RAG_FAISS_NLIST=32
RAG_FAISS_M=16          # PQ subquantizers
RAG_FAISS_NBITS=8

# --- qdrant ---
RAG_QDRANT_URL=http://localhost:6333
RAG_QDRANT_COLLECTION=rag_chunks

# --- retrieval ---
RAG_RRF_K=60
RAG_TOP_K=10
